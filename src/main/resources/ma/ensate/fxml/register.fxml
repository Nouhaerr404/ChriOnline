<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="ma.ensate.client.views.RegisterView"
      alignment="CENTER"
      spacing="12"
      style="-fx-background-color: #f0f4f8; -fx-padding: 40;">

    <!-- TITRE -->
    <Label text="ChriOnline"
           style="-fx-font-size: 28px; -fx-font-weight: bold;
                  -fx-text-fill: #1a73e8;"/>
    <Label text="Créer un compte"
           style="-fx-font-size: 14px; -fx-text-fill: #666;"/>

    <!-- CARTE -->
    <VBox spacing="12"
          style="-fx-background-color: white;
                 -fx-padding: 25;
                 -fx-background-radius: 10;
                 -fx-effect: dropshadow(gaussian, #ccc, 10, 0, 0, 2);"
          maxWidth="420">

        <!-- NOM -->
        <Label text="Nom complet"
               style="-fx-font-weight: bold; -fx-text-fill: #333;"/>
        <TextField fx:id="nomField"
                   promptText="Votre nom complet"
                   style="-fx-padding: 10; -fx-background-radius: 5;
                          -fx-border-color: #ddd; -fx-border-radius: 5;"/>

        <!-- EMAIL -->
        <Label text="Email"
               style="-fx-font-weight: bold; -fx-text-fill: #333;"/>
        <TextField fx:id="emailField"
                   promptText="Votre email"
                   style="-fx-padding: 10; -fx-background-radius: 5;
                          -fx-border-color: #ddd; -fx-border-radius: 5;"/>

        <!-- MOT DE PASSE -->
        <Label text="Mot de passe (min. 6 caractères)"
               style="-fx-font-weight: bold; -fx-text-fill: #333;"/>
        <PasswordField fx:id="passwordField"
                       promptText="Votre mot de passe"
                       style="-fx-padding: 10; -fx-background-radius: 5;
                              -fx-border-color: #ddd; -fx-border-radius: 5;"/>

        <!-- ADRESSE -->
        <Label text="Adresse (optionnel)"
               style="-fx-font-weight: bold; -fx-text-fill: #333;"/>
        <TextField fx:id="adresseField"
                   promptText="Votre adresse"
                   style="-fx-padding: 10; -fx-background-radius: 5;
                          -fx-border-color: #ddd; -fx-border-radius: 5;"/>

        <!-- TÉLÉPHONE -->
        <Label text="Téléphone (optionnel)"
               style="-fx-font-weight: bold; -fx-text-fill: #333;"/>
        <TextField fx:id="telField"
                   promptText="Votre téléphone"
                   style="-fx-padding: 10; -fx-background-radius: 5;
                          -fx-border-color: #ddd; -fx-border-radius: 5;"/>

        <!-- MESSAGE -->
        <Label fx:id="messageLabel"
               text=""
               style="-fx-font-size: 12px;"
               wrapText="true"/>

        <!-- BOUTON REGISTER -->
        <Button fx:id="registerButton"
                text="S'inscrire"
                onAction="#handleRegister"
                maxWidth="Infinity"
                style="-fx-background-color: #34a853;
                       -fx-text-fill: white;
                       -fx-font-size: 14px;
                       -fx-padding: 12;
                       -fx-background-radius: 5;
                       -fx-cursor: hand;"/>

        <!-- LIEN LOGIN -->
        <HBox alignment="CENTER" spacing="5">
            <Label text="Déjà un compte ?"
                   style="-fx-text-fill: #666;"/>
            <Hyperlink text="Se connecter"
                       onAction="#allerLogin"
                       style="-fx-text-fill: #1a73e8;"/>
        </HBox>

    </VBox>
</VBox>