<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="620.0" prefWidth="900.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ma.ensate.client.views.AdminProduitDetailsView">
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="header-section">
               <children>
                  <Button onAction="#retourner" styleClass="secondary-btn" text="Retour Admin" />
                  <Label text="Details Produit (Admin)" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="24.0" />
                     </font>
                  </Label>
               </children>
               <padding>
                  <Insets bottom="16.0" left="20.0" right="20.0" top="20.0" />
               </padding>
            </HBox>

            <HBox spacing="30.0" VBox.vgrow="ALWAYS">
               <children>
                  <VBox alignment="TOP_CENTER" prefWidth="320.0" spacing="10.0">
                     <children>
                        <AnchorPane prefHeight="320.0" prefWidth="320.0" styleClass="product-image-container">
                           <children>
                              <Label alignment="CENTER" text="IMAGE" textFill="#95a5a6" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                                 <font>
                                    <Font name="System Bold" size="24.0" />
                                 </font>
                              </Label>
                              <ImageView fx:id="produitImageView" fitHeight="320.0" fitWidth="320.0" pickOnBounds="true" preserveRatio="true" />
                           </children>
                        </AnchorPane>
                     </children>
                  </VBox>

                  <VBox spacing="14.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Label fx:id="nomLabel" text="Nom du Produit" textFill="#2c3e50">
                           <font>
                              <Font name="System Bold" size="32.0" />
                           </font>
                        </Label>
                        <Label fx:id="categorieLabel" text="Categorie" textFill="#7f8c8d">
                           <font>
                              <Font size="18.0" />
                           </font>
                        </Label>
                        <Label fx:id="prixLabel" text="0.00 MAD" textFill="#27ae60">
                           <font>
                              <Font name="System Bold" size="28.0" />
                           </font>
                        </Label>
                        <Label text="Description" textFill="#34495e">
                           <font>
                              <Font name="System Bold" size="16.0" />
                           </font>
                        </Label>
                        <Label fx:id="descriptionLabel" text="Description" wrapText="true" />
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                           <children>
                              <Label text="Stock:" textFill="#34495e">
                                 <font>
                                    <Font name="System Bold" size="16.0" />
                                 </font>
                              </Label>
                              <Label fx:id="stockLabel" text="0" textFill="#e67e22">
                                 <font>
                                    <Font name="System Bold" size="16.0" />
                                 </font>
                              </Label>
                           </children>
                        </HBox>
                        <AnchorPane VBox.vgrow="ALWAYS" />
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                           <children>
                              <Button onAction="#modifierProduit" styleClass="primary-btn" text="Modifier" />
                              <Button onAction="#supprimerProduit" styleClass="danger-btn" text="Supprimer" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
               <padding>
                  <Insets bottom="28.0" left="26.0" right="26.0" top="10.0" />
               </padding>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
